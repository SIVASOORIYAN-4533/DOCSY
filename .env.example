# Backend
NODE_ENV=development
PORT=5001
PORT_SEARCH_LIMIT=20
JWT_SECRET=replace_with_a_long_random_secret

# Database (recommended for Render production: MongoDB Atlas)
DB_PROVIDER=sqlite
DB_FALLBACK_TO_SQLITE=true
MONGODB_URI=
# Alias also supported by backend config:
# MONGO_URI=
MONGODB_DB_NAME=smartdoc
SQLITE_DB_PATH=smartdoc.db

# CORS / OAuth / frontend origin
FRONTEND_BASE_URL=http://localhost:5173
OAUTH_BASE_URL=http://localhost:5001
# Comma-separated list supported
CORS_ORIGIN=http://localhost:5173

# Storage
UPLOAD_DIR=uploads

# AI
GEMINI_API_KEY=

# OAuth providers
# Required for Google sign-in
GOOGLE_CLIENT_ID=
# Optional in current Google flow
GOOGLE_CLIENT_SECRET=
# Required for GitHub sign-in
GITHUB_CLIENT_ID=
# Required for GitHub sign-in
GITHUB_CLIENT_SECRET=

# Frontend build env (Vercel)
# Set to your Render backend URL in production, e.g. https://smartdoc-api.onrender.com
VITE_API_BASE_URL=
VITE_PORT=5173
